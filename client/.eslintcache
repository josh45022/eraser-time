ost</button>\n        <button onClick={()=>toggleCanEdit(prevState => !prevState)}>Cancel</button>\n      </>\n    //   }\n    // </div>\n    )\n}\n\nexport default Post",["82","83"],"/Users/joshuabenbaba/Documents/level-6-capstone/client/src/components/Comment.js",[],"/Users/joshuabenbaba/Documents/level-6-capstone/client/src/context/UserContext.js",[],["84","85"],"/Users/joshuabenbaba/Documents/level-6-capstone/client/src/components/Auth.js",[],"/Users/joshuabenbaba/Documents/level-6-capstone/client/src/index.js",[],"/Users/joshuabenbaba/Documents/level-6-capstone/client/src/components/NavBar.js",[],"/Users/joshuabenbaba/Documents/level-6-capstone/client/src/components/Public.js",["86"],"import React, {useState, useEffect} from \"react\"\nimport User from \"./User.js\"\nconst axios = require(\"axios\")\n\nfunction Public() {\n    const userAxios = axios.create()\n\n    userAxios.interceptors.request.use(config => {\n        const token = localStorage.getItem(\"token\")\n        config.headers.Authorization = `Bearer ${token}`\n        return config\n    })\n\n    const [users, setUsers] = useState([])\n    const [isLoading, setIsLoading] = useState(true)\n    const getData = (data) => {\n        setUsers(data)\n        return setIsLoading(prev => !prev)\n    }\n\n\n    \n    useEffect(()=>{userAxios.get(\"/api/users\")\n        .then(res => getData(res.data))\n        .catch(err => console.log(err.response.data.errMsg))\n        },\n        []\n    )\n\n\n    \n    return (\n        <div className=\"publicPostsHolder\">\n            {isLoading?<h1>loading...</h1>:users.map(user => <User {...user}/>)}\n        </div>\n    )\n\n}\n\nexport default Public","/Users/joshuabenbaba/Documents/level-6-capstone/client/src/components/AuthForm.js",["87"],"import React, {useState} from \"react\"\n\nfunction AuthForm(props) {\n    const {\n        handleChange,\n        handleSubmit, \n        inputs: {\n            username,\n            password\n        },\n        btnText\n    } = props\n    return (\n        <form onSubmit={handleSubmit}>\n        <input \n          type=\"text\" \n          name=\"username\" \n          value={username} \n          onChange={handleChange} \n          placeholder=\"Username\"/>\n        <input \n          type=\"text\" \n          name=\"password\" \n          value={password} \n          onChange={handleChange} \n          placeholder=\"Password\"/>\n        <button>{btnText}</button>\n      </form>\n    )\n}\n\nexport default AuthForm",["88","89"],"/Users/joshuabenbaba/Documents/level-6-capstone/client/src/components/PublicPost.js",["90"],"/Users/joshuabenbaba/Documents/level-6-capstone/client/src/components/PostForm.js",[],"/Users/joshuabenbaba/Documents/level-6-capstone/client/src/components/PostEditForm.js",[],"/Users/joshuabenbaba/Documents/level-6-capstone/client/src/components/Profile.js",["91","92","93","94","95"],"/Users/joshuabenbaba/Documents/level-6-capstone/client/src/components/User.js",["96"],"/Users/joshuabenbaba/Documents/level-6-capstone/client/src/components/YourPosts.js",["97","98","99"],"import React, {useContext, useEffect} from \"react\"\nimport {Link} from \"react-router-dom\"\nimport { UserContext } from \"../context/UserContext.js\"\nimport PostForm from \"./PostForm.js\"\nimport PostList from \"./PostList.js\"\nfunction YourPosts() {\n    const {\n        user: {\n            username\n        },\n        getUserPosts,\n        addPost,\n        posts,\n        logout\n    } = useContext(UserContext)\n\n\n\n    useEffect(getUserPosts, [])\n    return (\n        <>\n        <h1 style={{marginTop: \"30px\"}}>Welcome {username}!</h1>\n        <br />\n        <h3>Your posts</h3>\n        <br />\n            <PostList posts={posts}/>\n            <h3 style={{marginTop: 50}}>Add a New Post</h3>\n            <PostForm addPost={addPost} />\n        </>\n    )\n}\n\n\nexport default YourPosts",["100","101"],"/Users/joshuabenbaba/Documents/level-6-capstone/client/src/reportWebVitals